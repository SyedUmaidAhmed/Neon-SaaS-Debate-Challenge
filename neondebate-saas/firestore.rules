rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: debates
    // Document ID: {debateId}
    // Fields:
    //   - userId: string (required) - owner of the debate
    //   - topic: string (required) - debate topic
    //   - createdAt: number (required) - timestamp
    //   - status: string (optional) 
    //   - history: list of objects (optional)
    //   - article: map of body and summaryPoints (optional)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidDebate(data) {
      return data.keys().hasAll(['userId', 'topic', 'createdAt']) &&
             data.userId is string &&
             data.topic is string &&
             data.createdAt is number &&
             (data.keys().hasOnly(['userId', 'topic', 'status', 'createdAt', 'history', 'article'])) &&
             (!('status' in data) || data.status is string) &&
             (!('history' in data) || data.history is list) && 
             (!('article' in data) || data.article is map);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid']) &&
             data.uid is string &&
             (data.keys().hasOnly(['uid', 'email', 'displayName', 'photoURL', 'lastLoginAt'])) &&
             (!('email' in data) || data.email is string || data.email == null) &&
             (!('displayName' in data) || data.displayName is string || data.displayName == null) &&
             (!('photoURL' in data) || data.photoURL is string || data.photoURL == null) &&
             (!('lastLoginAt' in data) || data.lastLoginAt is string);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.uid == userId && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && 
                       request.resource.data.uid == resource.data.uid && 
                       isValidUser(request.resource.data);
    }

    match /debates/{debateId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && isValidDebate(request.resource.data);
      allow update: if isOwner(resource.data.userId) &&
                       isOwner(request.resource.data.userId) &&
                       request.resource.data.createdAt == resource.data.createdAt &&
                       isValidDebate(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
